# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
DEMO_MODE=false

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/stockpulse

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRE=7d

# ── Upstox API ────────────────────────────────────────────────────────────────
# Get credentials from: https://upstox.com/developer/api-documentation/get-started
# Preferred for local/dev: generate an access token in the Upstox portal and put it
# in UPSTOX_ACCESS_TOKEN. Do not paste that token into UPSTOX_AUTH_CODE.
# NOTE: UPSTOX_AUTH_CODE is the short single-use OAuth callback code, not the JWT-like
#       access token shown in the portal. It must be exchanged immediately.
UPSTOX_ACCESS_TOKEN=your_upstox_access_token
UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_AUTH_CODE=your_upstox_auth_code
UPSTOX_REDIRECT_URI=http://localhost:5001/callback

# ── News API (optional) ───────────────────────────────────────────────────────
# https://newsapi.org
NEWS_API_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
