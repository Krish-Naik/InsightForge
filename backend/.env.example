# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/stockpulse

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRE=7d

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
