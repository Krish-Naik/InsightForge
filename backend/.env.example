# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/insightforge

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL=60
REDIS_SCANNER_TTL=300

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRE=7d

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
ENABLE_RATE_LIMITING=true

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=60

# ── External APIs ────────────────────────────────────────────────────────────
# Yahoo Finance (used internally, no key required)
# Groq API for AI insights (if using marketInsightsService AI features)
GROQ_API_KEY=

# ── Email (OTP) ─────────────────────────────────────────────────────────────
# SMTP settings for sending OTP emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=StockPulse <noreply@stockpulse.app>
